# Autonax Panel - Environment Variables
# Copy this file to .env.local and fill in your values

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Autonax

# Auth
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
JWT_SECRET=your-super-secret-jwt-key-here

# EDM E-Fatura (GIB / Entegratör)
EDM_API_URL=https://earsiv.ggmm.com.tr/api
EDM_USERNAME=
EDM_PASSWORD=
EDM_VKN=
EDM_GONDERICI_ETIKET=

# Ödeme Geçidi - İyzico
IYZICO_API_KEY=
IYZICO_SECRET_KEY=
